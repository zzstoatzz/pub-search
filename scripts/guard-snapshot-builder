#!/usr/bin/env python3
"""Bound snapshot-builder runtime and recover missed scheduled starts."""

from __future__ import annotations

import argparse
import json
import subprocess
import time
import urllib.request
from typing import Any

from fly_machines import fly_binary, machine_list, select_builder
from watchdog_checks import snapshot_age_minutes

MAX_RUN_MINUTES = 50
RECOVERY_AGE_MINUTES = 90
BACKEND = "https://leaflet-search-backend.fly.dev"


def latest_started_at(machine: dict[str, Any]) -> float | None:
    timestamps = [
        event.get("timestamp", 0) / 1000
        for event in machine.get("events", [])
        if event.get("type") == "start" and event.get("status") == "started"
    ]
    return max(timestamps, default=0) or None


def decide_action(
    builder: dict[str, Any],
    snapshot_age: float,
    now: float,
    max_run_minutes: int = MAX_RUN_MINUTES,
    recovery_age_minutes: int = RECOVERY_AGE_MINUTES,
) -> tuple[str, str]:
    state = builder.get("state")
    if state == "started":
        started_at = latest_started_at(builder)
        if started_at is None:
            return "error", "started builder has no start event timestamp"
        run_age = (now - started_at) / 60
        if run_age > max_run_minutes:
            return "stop", f"builder runtime is {run_age:.0f}m (limit {max_run_minutes}m)"
        return "none", f"builder running for {run_age:.0f}m"
    if state == "stopped":
        if snapshot_age > recovery_age_minutes:
            return "start", f"snapshot age is {snapshot_age:.0f}m (recovery threshold {recovery_age_minutes}m)"
        return "none", f"snapshot age is {snapshot_age:.0f}m"
    return "error", f"builder is in unexpected state {state!r}"


def fetch_snapshot() -> dict[str, Any]:
    with urllib.request.urlopen(BACKEND + "/snapshot", timeout=10) as response:
        value = json.load(response)
    if not isinstance(value, dict):
        raise RuntimeError("snapshot response is not an object")
    return value


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--app", default="leaflet-search-backend")
    parser.add_argument("--max-run-minutes", type=int, default=MAX_RUN_MINUTES)
    parser.add_argument("--recovery-age-minutes", type=int, default=RECOVERY_AGE_MINUTES)
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()

    now = time.time()
    fly = fly_binary()
    builder = select_builder(machine_list(fly, args.app))
    age = snapshot_age_minutes(fetch_snapshot(), now)
    action, reason = decide_action(
        builder,
        age,
        now,
        max_run_minutes=args.max_run_minutes,
        recovery_age_minutes=args.recovery_age_minutes,
    )
    print(f"action={action}: {reason}")

    if action == "error":
        return 1
    if action == "none" or args.dry_run:
        return 0

    subprocess.run([fly, "machine", action, builder["id"], "-a", args.app], check=True)
    updated = select_builder(machine_list(fly, args.app))
    expected = "started" if action == "start" else "stopped"
    if updated.get("state") != expected:
        raise RuntimeError(f"builder state is {updated.get('state')!r}, expected {expected!r}")
    print(f"verified builder {builder['id']} is {expected}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

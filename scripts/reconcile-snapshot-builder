#!/usr/bin/env python3
"""Reconcile the scheduled snapshot builder to the serving image digest."""

from __future__ import annotations

import argparse
import subprocess
import sys

from fly_machines import fly_binary, image_uri, machine_list, select_builder, select_serving


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--app", default="leaflet-search-backend")
    parser.add_argument("--version", required=True, help="source revision stored in BUILDER_VERSION")
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()

    fly = fly_binary()
    machines = machine_list(fly, args.app)
    builder = select_builder(machines)
    serving = select_serving(machines)
    target_image = image_uri(serving)
    was_running = builder.get("state") != "stopped"

    command = [
        fly,
        "machine",
        "update",
        builder["id"],
        "-a",
        args.app,
        "--image",
        target_image,
        "--env",
        f"BUILDER_VERSION={args.version}",
        "--env",
        "BUILDER_TIMEOUT_SECS=2700",
        "--env",
        "TURSO_DISABLE_KEEPALIVE=1",
        "--skip-start",
        "--yes",
    ]
    if builder.get("state") != "stopped":
        print("builder is running; update will cancel the unfinished pointer-last build", file=sys.stderr)
    print("reconciling builder to", target_image)
    if args.dry_run:
        print("DRY RUN:", " ".join(command))
        return 0

    subprocess.run(command, check=True)
    if was_running:
        subprocess.run([fly, "machine", "start", builder["id"], "-a", args.app], check=True)
    updated = select_builder(machine_list(fly, args.app))
    if updated.get("image_ref", {}).get("digest") != serving.get("image_ref", {}).get("digest"):
        raise RuntimeError("builder image digest does not match serving after update")
    env = updated.get("config", {}).get("env", {})
    actual_version = env.get("BUILDER_VERSION")
    if actual_version != args.version:
        raise RuntimeError(f"builder version is {actual_version!r}, expected {args.version!r}")
    required_env = {
        "BUILDER_MODE": "1",
        "BUILDER_CHANNEL": "prod",
        "BUILDER_ALLOW_PROD": "1",
        "BUILDER_TIMEOUT_SECS": "2700",
        "TURSO_DISABLE_KEEPALIVE": "1",
    }
    if missing := {key: value for key, value in required_env.items() if env.get(key) != value}:
        raise RuntimeError(f"builder environment invariant failed: {missing}")
    if updated.get("config", {}).get("schedule") != "hourly":
        raise RuntimeError("builder lost its hourly schedule during update")
    if was_running and updated.get("state") != "started":
        raise RuntimeError("builder was running before reconciliation but was not restarted")
    print(f"verified builder {updated['id']} at serving digest with BUILDER_VERSION={actual_version}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

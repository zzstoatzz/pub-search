#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "httpx",
#     "websockets",
#     "atproto",
#     "pydantic-settings",
# ]
# ///
"""
Watchdog: ping @zzstoatzz.io on bsky when pub-search ingestion is wedged.

Checks whether the tap's firehose cursor is ADVANCING. Reads the cursor twice
over a short window; if it doesn't move (or the stats endpoint is unreachable),
ingestion is wedged and we post a mention from the pub-search account.

Why advancement, not "behind relay head": the old design subtracted the tap's
cursor from a hardcoded relay's head seq. That broke every time we switched
relays — different relays have different seq spaces, so the subtraction became
meaningless and fired spurious "N billion seq behind" alerts (esp. when tap
momentarily reports firehose:0 mid-reconnect). Cursor advancement is
relay-agnostic and reconnect-tolerant, and it directly detects the real failure
mode: a wedged tap whose cursor is frozen.

Background: 2026-05-27 a relay rebuild wedged the tap and ingestion was dead for
~14.5h before anyone noticed (cursor frozen the whole time). See docs/tap.md.

Creds: ATPROTO_HANDLE / ATPROTO_PASSWORD (from .env, or env / ENV_FILE).

Usage:
    ./scripts/ingestion-watchdog                 # check; post only if stalled
    ./scripts/ingestion-watchdog --test          # post a wiring-test mention, then delete it
    ./scripts/ingestion-watchdog --window 25     # seconds between cursor reads
"""

import argparse
import datetime
import os
import sys
import time

import httpx
from atproto import Client, client_utils
from pydantic_settings import BaseSettings, SettingsConfigDict

TAP_CURSORS = "https://leaflet-search-tap.fly.dev/stats/cursors"
ALERT_HANDLE = "zzstoatzz.io"
# substring used to recognize our own prior alerts (dedup) — keep in the message
ALERT_MARKER = "pub-search ingestion looks stalled"
# seconds to wait between the two cursor reads. A healthy tap advances its
# firehose cursor continuously; a wedged one stays put.
DEFAULT_WINDOW_SECS = 25
# tap reports firehose:0 briefly while reconnecting to the relay. Re-poll across
# this window before treating a 0/None as real, so a reconnect blip never alerts.
_RECONNECT_RETRY_SECS = 20


class Settings(BaseSettings):
    model_config = SettingsConfigDict(
        env_file=os.environ.get("ENV_FILE", ".env"), extra="ignore"
    )
    atproto_handle: str = ""
    atproto_password: str = ""


def _tap_seq_raw() -> int | None:
    r = httpx.get(TAP_CURSORS, timeout=15)
    r.raise_for_status()
    return r.json().get("firehose")


def _tap_seq_live() -> int | None:
    """tap firehose cursor, tolerating reconnect blips (firehose:0/None).

    Re-polls for up to _RECONNECT_RETRY_SECS so a momentary reconnect (cursor
    reads 0 until the first frame is processed) isn't mistaken for a wedge.
    Returns a positive seq, or None if it stays 0/None for the whole window.
    """
    deadline = time.monotonic() + _RECONNECT_RETRY_SECS
    while True:
        seq = _tap_seq_raw()
        if seq:  # nonzero, non-None
            return seq
        if time.monotonic() >= deadline:
            return None
        time.sleep(5)


def check(window_secs: int) -> tuple[bool, str]:
    try:
        seq1 = _tap_seq_live()
    except Exception as e:
        return True, f"tap /stats/cursors unreachable: {e!r}"
    if seq1 is None:
        return True, "firehose cursor stuck at 0 (reconnect-looping or not processing)"

    time.sleep(window_secs)

    try:
        seq2 = _tap_seq_live()
    except Exception as e:
        return True, f"tap /stats/cursors unreachable: {e!r}"
    if seq2 is None:
        return True, "firehose cursor stuck at 0 (reconnect-looping or not processing)"

    advanced = seq2 - seq1
    if advanced <= 0:
        return True, f"firehose cursor not advancing — frozen at {seq1:,} over {window_secs}s (wedged)"
    return False, f"healthy: firehose advanced {advanced:,} seq in {window_secs}s (~{advanced // window_secs:,}/s)"


def _post(client: Client, target_did: str, message: str):
    tb = client_utils.TextBuilder().mention(f"@{ALERT_HANDLE}", target_did).text(f" {message}")
    return client.send_post(tb)


def _alerted_within(client: Client, hours: int) -> bool:
    """True if this account already posted a stall alert in the last `hours`.

    Keeps a 15-min cron from spamming on a multi-hour stall. Errs toward posting
    (returns False) if anything is uncertain — better a dupe than a missed alert.
    """
    try:
        feed = client.get_author_feed(client.me.did, limit=15).feed
    except Exception:
        return False
    cutoff = datetime.datetime.now(datetime.timezone.utc) - datetime.timedelta(hours=hours)
    for item in feed:
        rec = getattr(item.post, "record", None)
        text = getattr(rec, "text", "") or ""
        if ALERT_MARKER not in text:
            continue
        created = getattr(rec, "created_at", None)
        if not created:
            return True
        try:
            if datetime.datetime.fromisoformat(created.replace("Z", "+00:00")) > cutoff:
                return True
        except ValueError:
            return True
    return False


def main() -> None:
    ap = argparse.ArgumentParser(description="pub-search ingestion watchdog")
    ap.add_argument("--test", action="store_true", help="post a wiring-test mention, then delete it")
    ap.add_argument("--window", type=int, default=DEFAULT_WINDOW_SECS, help="seconds between the two cursor reads")
    ap.add_argument("--dedup-hours", type=int, default=3, help="suppress repeat alerts within this window")
    args = ap.parse_args()

    settings = Settings()
    if not (settings.atproto_handle and settings.atproto_password):
        print("ATPROTO_HANDLE/ATPROTO_PASSWORD not set — skipping (configure to enable)")
        return

    client = Client()
    client.login(settings.atproto_handle, settings.atproto_password)
    target_did = client.resolve_handle(ALERT_HANDLE).did

    if args.test:
        resp = _post(client, target_did, "pub-search ingestion watchdog wiring test — ignore (auto-deleting).")
        print(f"posted test: {resp.uri}")
        client.delete_post(resp.uri)
        print("deleted test post — auth + posting confirmed")
        return

    stalled, detail = check(args.window)
    print(detail)
    if stalled:
        if _alerted_within(client, args.dedup_hours):
            print(f"stalled, but already alerted within {args.dedup_hours}h — not reposting")
        else:
            resp = _post(client, target_did, f"⚠️ {ALERT_MARKER} — {detail}. check leaflet-search-tap.fly.dev")
            print(f"ALERT posted: {resp.uri}")
        sys.exit(1)


if __name__ == "__main__":
    main()
